{
  "name": "onestreamrpg2extension",
  "private": true,
  "version": "0.0.0",
  "homepage": "./",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dev:overlay": "vite --mode overlay",
    "dev:panel": "vite --mode panel",
